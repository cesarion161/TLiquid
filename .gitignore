# Dependencies
node_modules/
.pnpm-store/

# Frontend build output
dist/
.vite/

# Rust / Tauri build output
src-tauri/target/
# Generated by tauri-build at compile time (schemas, etc.)
src-tauri/gen/

# Editor / OS
.DS_Store
*.local
*.log

# Env / secrets (TLiquid stores keys in the macOS Keychain, never in files —
# this is belt-and-suspenders)
.env
.env.*

# Updater signing keys (P2-007). The minisign PRIVATE key must NEVER be committed;
# it lives here locally and is mirrored to the GitHub secret TAURI_SIGNING_PRIVATE_KEY.
# The matching PUBLIC key is embedded in tauri.conf.json (safe to publish).
.tauri/

# Idea
.idea
