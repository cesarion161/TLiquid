{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TLiquid",
  "version": "0.2.0",
  "identifier": "com.tliquid.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cesarion161/TLiquid/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdERkRDNjE2QTZDQzk3MkIKUldRcmw4eW1Gc2I5ZlM3TkE5ZVlIWTlHVno1UnhiS00vRXRweFBJaEFkYzlDWWVESmsxbkwxWGoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.productivity",
    "shortDescription": "BYOK LLM translator in your menu bar.",
    "longDescription": "TLiquid is a tiny, open-source, macOS-first bring-your-own-key LLM translator that lives in the menu bar and translates selected text instantly.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "dmg": {
        "windowSize": {
          "width": 540,
          "height": 380
        },
        "appPosition": {
          "x": 150,
          "y": 190
        },
        "applicationFolderPosition": {
          "x": 390,
          "y": 190
        }
      }
    }
  }
}
