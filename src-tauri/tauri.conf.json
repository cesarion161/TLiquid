{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TLiquid",
  "version": "0.1.0",
  "identifier": "com.tliquid.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.productivity",
    "shortDescription": "BYOK LLM translator in your menu bar.",
    "longDescription": "TLiquid is a tiny, open-source, macOS-first bring-your-own-key LLM translator that lives in the menu bar and translates selected text instantly.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
